# ==========================================
# MUNDO AIMAS - VARIABLES DE ENTORNO VITE
# ==========================================
# ⚠️ IMPORTANTE: Solo las variables con prefijo VITE_ son expuestas al frontend.
# NO añadas claves maestras o tokens de servidor aquí.

# ------------------------------------------
# 1. SUPABASE (Requerido para Auth, DB y Storage)
# ------------------------------------------
VITE_SUPABASE_URL="tu_supabase_url_aqui"
VITE_SUPABASE_ANON_KEY="tu_supabase_anon_key_aqui"

# ------------------------------------------
# 2. GOOGLE MAPS 3D (Requerido para el mapa inmersivo)
# ------------------------------------------
# Debe ser una clave con permisos para:
# - Map Tiles API
# - Maps JavaScript API
# - Places API
# - Geocoding API
VITE_GOOGLE_MAPS_API_KEY="tu_google_maps_api_key_aqui"

# ------------------------------------------
# 3. GOOGLE GEMINI AI (Requerido para Onboarding Chat y Map Grounding)
# ------------------------------------------
VITE_GEMINI_API_KEY="tu_gemini_api_key_aqui"

# ==========================================
# VARIABLES DE SERVIDOR (NO usar VITE_)
# ==========================================
# Estas variables serán usadas en el futuro por Netlify Functions / Supabase Edge Functions.
# ANTHROPIC_API_KEY="tu_anthropic_key_aqui"
